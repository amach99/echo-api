# =============================================================================
# Echo API — Environment Variables
# Copy this file to .env and fill in all values before running the app.
# NEVER commit .env to source control.
# =============================================================================

# Application
ENV=development   # development | staging | production

# --- Database (PostgreSQL) ---
# Local docker-compose default:
DATABASE_URL=postgresql+asyncpg://echo_user:echo_dev_password@localhost:5432/echo_db

# --- Redis ---
# Local docker-compose default:
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_32_byte_hex_secret
JWT_REFRESH_SECRET_KEY=CHANGE_ME_generate_a_different_32_byte_hex_secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AWS S3 (Media uploads) ---
# Create an IAM user with AmazonS3FullAccess, generate access keys below.
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
S3_BUCKET_NAME=echo-media-dev

# --- ID Verification Provider (Yoti or Clear) ---
# Get sandbox credentials from: https://developers.yoti.com
ID_VERIFY_PROVIDER=yoti   # yoti | clear | mock (use mock for local dev)
ID_VERIFY_API_KEY=CHANGE_ME
ID_VERIFY_CLIENT_ID=CHANGE_ME
ID_VERIFY_WEBHOOK_SECRET=CHANGE_ME

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
